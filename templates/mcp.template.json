{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/servers/main/schemas/mcp.schema.json",
  "_generated_by": "legacy-to-agentic-ready",
  "_generated_at": "{{TIMESTAMP}}",

  "mcpServers": {
    "{{PROJECT_NAME}}-tools": {
      "command": "{{TOOL_COMMAND}}",
      "args": {{TOOL_ARGS}},
      "cwd": "{{PROJECT_ROOT}}",
      "env": {
        "{{ENV_VAR_1}}": "{{ENV_VALUE_1}}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "{{PROJECT_ROOT}}"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "{{PROJECT_ROOT}}"
      ]
    }
  }
}
